@page
@model SGPP.Web.Pages.Admin.Usuarios.Tutores.IndexModel
@{
    ViewData["Title"] = "Gestión de Tutores";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Gestión de Tutores Institucionales</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-page="/Admin/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active">Tutores (Empresas)</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <span><i class="fas fa-briefcase me-1"></i> Lista de Tutores</span>
            <a asp-page="./Create" class="btn btn-light btn-sm text-info fw-bold">
                <i class="fas fa-plus"></i> Nuevo Tutor
            </a>
        </div>
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Nombre Completo</th>
                        <th>Email</th>
                        <th>Empresa</th>
                        <th>Cargo</th>
                        <th>CI</th>
                        <th>Activo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Tutores)
                    {
                        <tr>
                            <td>@item.NombreCompleto</td>
                            <td>@item.Email</td>
                            <td>@item.Empresa</td>
                            <td>@item.Cargo</td>
                            <td>@item.Ci</td>
                             <td class="text-center">
                                @if(item.EsActivo) { <span class="badge bg-success">Si</span> } 
                                else { <span class="badge bg-danger">No</span> }
                            </td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
