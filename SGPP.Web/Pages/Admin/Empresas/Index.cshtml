@page
@model SGPP.Web.Pages.Admin.Empresas.IndexModel
@{
    ViewData["Title"] = "Gestión de Empresas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Gestión de Empresas (Centros de Práctica)</h1>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Nueva Empresa
    </a>
</div>

<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="SearchTerm" class="form-control" placeholder="Buscar por Razón Social o NIT..." value="@Model.SearchTerm">
        <button class="btn btn-outline-secondary" type="submit">Buscar</button>
    </div>
</form>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Razón Social</th>
            <th>NIT</th>
            <th>Rubro</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Centros)
        {
            <tr>
                <td>@item.RazonSocial</td>
                <td>@item.Nit</td>
                <td>@item.Rubro</td>
                <td>
                    <span class="badge bg-@(item.EstadoConvenio == SGPP.Domain.Enums.EstadoConvenio.Activo ? "success" : "warning")">
                        @item.EstadoConvenio
                    </span>
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                        <i class="fas fa-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
