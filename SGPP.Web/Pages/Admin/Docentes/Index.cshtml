@page
@model SGPP.Web.Pages.Admin.Docentes.IndexModel
@{
    ViewData["Title"] = "Gestión de Docentes";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Gestión de Docentes (Tutores Académicos)</h1>
    <div class="d-flex justify-content-between mb-4">
        <p class="text-muted">Administre los usuarios que aparecerán como opción para los estudiantes.</p>
        <a asp-page="Create" class="btn btn-primary"><i class="bi bi-person-plus-fill"></i> Nuevo Docente</a>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-table me-1"></i>
            Listado de Docentes Registrados
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Email</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Docentes)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Apellido</td>
                            <td>@item.Email</td>
                            <td>
                                @if(item.EsActivo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
