@page
@model SGPP.Web.Pages.Student.EditarAsignacionModel
@{
    ViewData["Title"] = "Editar Asignación";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-warning text-dark text-center py-3">
            <h3 class="mb-0">Corrección de Vinculación de Práctica</h3>
        </div>
        <div class="card-body p-4">
            <div class="alert alert-warning mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Use este formulario solo si cometió un error al seleccionar su Empresa o Docente. Si ya empezó su evaluación, tenga cuidado.
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-4">
                    <label class="form-label fw-bold">1. Centro de Práctica (Empresa)</label>
                    <select id="centroSelect" asp-for="SelectedCentroId" class="form-select form-select-lg" required>
                        <option value="">-- Seleccione una Empresa --</option>
                        @foreach (var centro in Model.Centros)
                        {
                            <option value="@centro.Id">@centro.RazonSocial</option>
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">2. Tutor Institucional (Supervisor)</label>
                    <select id="tutorSelect" asp-for="SelectedTutorId" class="form-select form-select-lg" required>
                        <!-- Loaded via JS logic similar to Vincular, but needs pre-fill handling -->
                        <option value="@Model.SelectedTutorId" selected>Mantener Actual (o seleccione tutor al cambiar empresa)</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">3. Tutor Académico (Docente)</label>
                    <select asp-for="SelectedTutorAcademicoId" class="form-select form-select-lg" required>
                        <option value="">-- Seleccione su Docente Guía --</option>
                        @foreach (var doc in Model.TutoresAcademicos)
                        {
                            <option value="@doc.Id">@doc.Nombre @doc.Apellido</option>
                        }
                    </select>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-page="Dashboard" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Copy paste Logic from Vincular but handle initial loading
        // Ideally verify pre-fill via server-rendered option or AJAX trigger
        
        document.getElementById('centroSelect').addEventListener('change', function() {
            var centroId = this.value;
            var tutorSelect = document.getElementById('tutorSelect');
            
            tutorSelect.innerHTML = '<option value="">Cargando...</option>';
            tutorSelect.disabled = true;

            if (centroId) {
                fetch(`?handler=Tutores&centroId=${centroId}`)
                    .then(response => response.json())
                    .then(data => {
                        tutorSelect.innerHTML = '<option value="">-- Seleccione un Tutor --</option>';
                        data.forEach(item => {
                            var option = document.createElement('option');
                            option.value = item.id;
                            option.text = item.nombre;
                            tutorSelect.appendChild(option);
                        });
                        tutorSelect.disabled = false;
                    })
                    .catch(error => {
                        console.error('Error:', error);
                    });
            }
        });
        
        // Trigger once on load to populate list for current selection?
        // Actually, easiest is: If user CHANGES Centro, we wipe Tutor. 
        // If user KEEPS Centro, current Tutor ID is bound.
        // We will trigger change manually IF needed, but for now we trust the "Mantener Actual" or force reload.
        // Actually, to be safe, let's load the tutors for the SELECTED Centro immediately
        
        document.addEventListener('DOMContentLoaded', function() {
             var centroId = document.getElementById('centroSelect').value;
             var currentTutorId = @Model.SelectedTutorId;
             
             if(centroId) {
                 fetch(`?handler=Tutores&centroId=${centroId}`)
                    .then(response => response.json())
                    .then(data => {
                        var tutorSelect = document.getElementById('tutorSelect');
                        tutorSelect.innerHTML = ''; // Clear "Mantener Actual" placeholder
                        
                        data.forEach(item => {
                            var option = document.createElement('option');
                            option.value = item.id;
                            option.text = item.nombre;
                            if (item.id == currentTutorId) option.selected = true;
                            tutorSelect.appendChild(option);
                        });
                    });
             }
        });
    </script>
}
