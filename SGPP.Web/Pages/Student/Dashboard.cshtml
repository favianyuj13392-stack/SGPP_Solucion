@page
@model SGPP.Web.Pages.Student.DashboardModel
@using SGPP.Domain.Enums
@{
    ViewData["Title"] = "Dashboard Estudiante";

    // Helper para colores de badges
    string GetStatusColor(EstadoAsignacion estado) => estado switch
    {
        EstadoAsignacion.EnProceso => "primary",
        EstadoAsignacion.Pendiente => "warning",
        EstadoAsignacion.Completado => "success",
        EstadoAsignacion.NoHabilitado => "danger",
        _ => "secondary"
    };
}

<div class="container mt-4">
    <!-- Header Bienvenida -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-0">Panel del Estudiante</h2>
            <p class="text-muted">Gestión de Prácticas Profesionales</p>
        </div>
        @if (Model.ActivePeriod != null)
        {
            <div class="badge bg-info text-dark fs-6">
                <i class="fas fa-calendar-alt me-1"></i> Periodo: @Model.ActivePeriod.CodigoGestion
            </div>
        }
    </div>

    @if (Model.Asignacion == null)
    {
        <!-- ESTADO 1: SIN PRACTICA REGISTRADA -->
        <div class="alert alert-info shadow-sm">
            <h4 class="alert-heading"><i class="fas fa-info-circle"></i> Bienvenido al Sistema de Prácticas</h4>
            <p>Aún no tienes ninguna práctica vinculada.</p>
            <hr>
            
            @if (Model.ActivePeriod != null)
            {
                <p class="mb-3">El periodo <strong>@Model.ActivePeriod.CodigoGestion</strong> está activo. Para comenzar, debes registrar tu práctica.</p>
                <a asp-page="/Student/Vincular" class="btn btn-primary btn-lg">
                    <i class="fas fa-link"></i> Vincular Nueva Práctica
                </a>
            }
            else
            {
                <p class="mb-0 text-danger">Actualmente no hay un periodo académico activo para registrar nuevas prácticas.</p>
            }
        </div>
    }
    else
    {
        <!-- ESTADO 2: CON PRACTICA (Resumen y Evaluación) -->
        <div class="row">
            <!-- Columna Izquierda: Datos de la Práctica -->
            <div class="col-md-5 mb-4">
                <div class="card shadow-sm h-100 border-primary">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-briefcase"></i> Tu Práctica Actual (@Model.Asignacion.Periodo.CodigoGestion)
                    </div>
                    <div class="card-body">
                        <h5 class="card-title text-primary">@Model.Asignacion.TutorInstitucional.CentroPractica.RazonSocial</h5>
                        <p class="text-muted mb-3">
                            <i class="fas fa-user-tie"></i> Tutor: @Model.Asignacion.TutorInstitucional.ApplicationUser.Nombre @Model.Asignacion.TutorInstitucional.ApplicationUser.Apellido
                        </p>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                Estado
                                <span class="badge bg-@GetStatusColor(Model.Asignacion.Estado)">@Model.Asignacion.Estado</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                Fecha Registro
                                <span class="text-secondary">@Model.Asignacion.FechaCreacion.ToShortDateString()</span>
                            </li>
                        </ul>
                        <!-- Opcion de editar solo si NO ha sido evaluado -->
                        <div class="mt-3 text-center">
                            <a asp-page="/Student/EditarAsignacion" class="btn btn-outline-secondary btn-sm w-100">
                                <i class="fas fa-edit"></i> Editar Datos
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna Derecha: Acciones de Evaluación -->
            <div class="col-md-7 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white border-bottom-0 pt-3">
                        <h5 class="card-title mb-0"><i class="fas fa-clipboard-check text-success"></i> Evaluaciones</h5>
                    </div>
                    <div class="card-body">
                        <!-- Autoevaluación -->
                        <div class="d-flex align-items-center mb-4 p-3 border rounded @(Model.HasCompletedFormA ? "bg-light" : "")">
                            <div class="flex-shrink-0 display-6 text-@(Model.HasCompletedFormA ? "success" : "secondary")">
                                <i class="fas fa-user-edit"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="mb-1">Autoevaluación del Estudiante (Formulario A)</h6>
                                <small class="text-muted">Debes completar este formulario como parte de tu nota final.</small>
                            </div>
                            <div class="ms-3">
                                @if (Model.HasCompletedFormA)
                                {
                                    <button class="btn btn-success" disabled>
                                        <i class="fas fa-check-circle"></i> Completado
                                    </button>
                                }
                                else
                                {
                                    @if (Model.IsEvaluationWindowOpen)
                                    {
                                        <a asp-page="/Student/FormularioA" class="btn btn-primary">
                                            Realizar
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary" disabled>Cerrado</button>
                                    }
                                }
                            </div>
                        </div>

                        <!-- ALERTA DE DISCREPANCIA DE PERIODO -->
                        @if (Model.ActivePeriod != null && Model.Asignacion.PeriodoId != Model.ActivePeriod.Id)
                        {
                            <div class="alert alert-warning border-warning mb-3">
                                <div class="d-flex">
                                    <i class="fas fa-history fs-4 me-3"></i>
                                    <div>
                                        <strong>Periodo Anterior Detectado</strong><br />
                                        Esta práctica pertenece al periodo <strong>@Model.Asignacion.Periodo.CodigoGestion</strong>, 
                                        pero el periodo académico actual es <strong>@Model.ActivePeriod.CodigoGestion</strong>.
                                        Las fechas de evaluación mostradas corresponden a tu periodo asignado.
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- ALERTA DE FECHAS (Solo si NO está abierto y NO ha completado) -->
                        @if (!Model.IsEvaluationWindowOpen && !Model.HasCompletedFormA)
                        {
                            <div class="alert alert-danger border-danger">
                                <div class="d-flex">
                                    <i class="fas fa-clock fs-4 me-3"></i>
                                    <div>
                                        <strong>Fuera de Periodo de Evaluación (@Model.Asignacion.Periodo.CodigoGestion)</strong><br />
                                        Las evaluaciones para este periodo están habilitadas únicamente del 
                                        <strong>@Model.Asignacion.Periodo.FechaInicioEvaluacion.ToShortDateString()</strong> al 
                                        <strong>@Model.Asignacion.Periodo.FechaFinEvaluacion.ToShortDateString()</strong>.
                                    </div>
                                </div>
                            </div>
                        }

                        <hr />
                        
                        <!-- Evaluación Tutor (Informativo) -->
                        <div class="d-flex align-items-center p-3 border rounded bg-light">
                             <div class="flex-shrink-0 display-6 text-muted">
                                <i class="fas fa-building"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <h6 class="mb-1">Evaluación de la Empresa (Formulario B)</h6>
                                <small class="text-muted">Tu tutor institucional debe llenar este formulario desde su cuenta.</small>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    }
</div>
