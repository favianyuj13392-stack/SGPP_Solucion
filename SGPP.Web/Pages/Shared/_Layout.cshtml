<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGPP UCB</title>
    <link rel="icon" type="image/png" href="~/img/ucb_logo.png" />
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SGPP.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-ucb-blue sticky-top navbar-ucb mb-4">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <img src="~/img/ucb_logo.png" alt="UCB Logo" height="50" class="d-inline-block align-middle me-2">
                    SGPP UCB
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Inicio</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Admin/Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Administración
                                </a>
                                <ul class="dropdown-menu shadow" aria-labelledby="adminDropdown">
                                    <li><h6 class="dropdown-header">Gestión General</h6></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Periodos/Index"><i class="fas fa-calendar-alt me-2"></i>Periodos</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Empresas/Index"><i class="fas fa-building me-2"></i>Empresas</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">Usuarios</h6></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Usuarios/Estudiantes/Index"><i class="fas fa-user-graduate me-2"></i>Estudiantes</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Usuarios/Tutores/Index"><i class="fas fa-user-tie me-2"></i>Tutores Empresa</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Docentes/Index"><i class="fas fa-chalkboard-teacher me-2"></i>Docentes</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Herramientas
                                </a>
                                <ul class="dropdown-menu shadow" aria-labelledby="reportsDropdown">
                                    <li><a class="dropdown-item" asp-page="/Admin/Reports/Sustainability"><i class="fas fa-leaf me-2"></i>Reporte Sostenibilidad</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Reports/DashboardDSS"><i class="fas fa-chart-line me-2"></i>Dashboard Estratégico</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Busqueda/Index"><i class="fas fa-search me-2"></i>Búsqueda Avanzada</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Usuarios/Import"><i class="fas fa-file-upload me-2"></i>Carga Masiva</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("TutorAcademico"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Academic/Dashboard">Mis Estudiantes</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle me-1"></i> Hola, @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                    <li>
                                        <form class="form-inline" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Account/Login")" method="post">
                                            <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link login-btn" asp-page="/Account/Login"><i class="fas fa-sign-in-alt me-1"></i> Iniciar Sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top">
        <div class="container text-center">
            <small>&copy; 2025 - <strong>Sistema de Gestión de Prácticas Pre-Profesionales</strong> - Universidad Católica Boliviana</small> 
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>